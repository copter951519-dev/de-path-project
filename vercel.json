{
  "version": 2,
  "builds": [
    {
      "src": "DE-Path/backend/server.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "DE-Path/frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "DE-Path/backend/server.mjs"
    },
    {
      "src": "/(.*\\.(css|js|html|png|jpg|ico|svg))",
      "dest": "DE-Path/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "DE-Path/frontend/index.html"
    }
  ]
}
