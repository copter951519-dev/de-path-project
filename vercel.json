{
  "version": 2,
  "builds": [
    {
      "src": "DE-Path/backend/server.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "DE-Path/backend/server.mjs"
    },
    {
      "src": "/(.*\\.(css|js|html|png|jpg|svg|ico|woff|woff2))",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "DE-Path/backend/server.mjs"
    }
  ]
}